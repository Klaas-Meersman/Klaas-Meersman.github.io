---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Research"
  description="Research projects and interests of Klaas Meersman."
>
  <h1>Research</h1>
  <p class="lead">
    Most indoor lighting is still a fixed beam with the sometimes the option to dim. I work on
    luminaires that can put light exactly where it's needed and adapt as the
    daylight changes, using virtual reality and digital twins to design and test
    them before they're built. Four objectives:
  </p>

  {
    projects.map((project) => (
      <article class="card">
        <h3>
          {project.url ? <a href={project.url}>{project.title}</a> : project.title}
        </h3>
        {project.period && <p class="muted small">{project.period}</p>}
        <p>{project.summary}</p>
        {project.tags && project.tags.length > 0 && (
          <ul class="pill-row">
            {project.tags.map((t) => (
              <li class="tag">{t}</li>
            ))}
          </ul>
        )}
      </article>
    ))
  }
</BaseLayout>

<style>
  .small {
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }
</style>
