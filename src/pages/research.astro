---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Research"
  description="Research projects and interests of Klaas Meersman."
>
  <h1>Research</h1>
  <p class="lead">
    A high-fidelity VR framework for the human-centric evaluation of spatially
    adaptive lighting.
  </p>
  <p>
    Modern lighting increasingly aspires to be human-centric and context-aware,
    yet most indoor systems are still static luminaires with only room- or
    zone-level dimming. Pixelated high-power LED arrays with projection optics
    change that: they can shape a light distribution finely in space, time, and
    spectrum, delivering light where and when it is needed. What is missing are
    validated design methods, metrics, and evaluation frameworks that account
    for the interaction between electric light, daylight, and human perception.
  </p>
  <p>
    My PhD tackles this gap with virtual reality and digital twins — enabling
    controlled, repeatable evaluation of adaptive, daylight-integrated lighting
    with explicit consideration of both <em>visual</em> and
    <em>non-visual</em> (photoreceptor-mediated) responses. The work is
    organised around four objectives.
  </p>

  {
    projects.map((project) => (
      <article class="card">
        <h3>
          {project.url ? <a href={project.url}>{project.title}</a> : project.title}
        </h3>
        {project.period && <p class="muted small">{project.period}</p>}
        <p>{project.summary}</p>
        {project.tags && project.tags.length > 0 && (
          <ul class="pill-row">
            {project.tags.map((t) => (
              <li class="tag">{t}</li>
            ))}
          </ul>
        )}
      </article>
    ))
  }
</BaseLayout>

<style>
  .small {
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }
</style>
