---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../consts";

// A lightweight web CV. Edit the arrays below.
//
// `supervisors`, `grade`, `activities`, and `thesis` are optional — leave them
// out if an entry doesn't need them. `supervisors` and `thesis` may contain links.
const education = [
  {
    when: "Nov 2025 – present",
    what: "PhD in Engineering Technology",
    where: "KU Leuven, Light & Lighting Laboratory",
    supervisors:
      '<a href="https://www.kuleuven.be/wieiswie/en/person/00089830">Prof. Youri Meuret</a>, <a href="https://www.kuleuven.be/wieiswie/en/person/00153950">Prof. Maria Torres Vega</a>, and <a href="https://www.kuleuven.be/wieiswie/en/person/00058788">Prof. Wouter Ryckaert</a>',
  },
  {
    when: "Sep 2022 – Aug 2025",
    what: "Master of Science, Engineering Technology — Electronics-ICT",
    where: "KU Leuven, Ghent Campus",
    grade: "Magna cum laude",
    thesis:
      'Studying in-process memory isolation mechanisms — supervised by <a href="https://stijn-volckaert.github.io/personal/">Prof. Stijn Volckaert</a>',
  },
  {
    when: "Sep 2018 – Jun 2022",
    what: "Bachelor of Science, Electronics-ICT",
    where: "Hogeschool Odisee",
    grade: "Cum laude",
    activities:
      "Erasmus+ exchange at Universitat Politècnica de València, Spain",
    thesis:
      "Design and implementation of an electronic measurement system based on electrochemical organic transistors (OECTs) functionalized with aptamers",
  },
  {
    when: "Sep 2016 – Jun 2018",
    what: "Bachelor of Science, Economics",
    where: "Ghent University",
    activities: "Unfinished.",
  },
];

const experience = [
  {
    when: "Nov 2025 – present",
    what: "Doctoral researcher",
    where: "Light & Lighting Laboratory, KU Leuven",
  },
];

const skills = [
  "Lighting measurement",
  "Data analysis (Python)",
  "Scientific writing",
  "Dutch (native)",
  "English (fluent)",
];
---

<BaseLayout title="CV" description="Curriculum vitae of Klaas Meersman.">
  <h1>Curriculum Vitae</h1>
  <p class="muted">
    {SITE.name} · {SITE.role}, {SITE.affiliation}
  </p>

  <h2>Education</h2>
  <ul class="timeline">
    {
      education.map((e) => (
        <li>
          <span class="when">{e.when}</span>
          <span class="what">
            <strong>{e.what}</strong>
            <br />
            <span class="muted">{e.where}</span>
            {e.supervisors && (
              <div class="detail muted">
                Promotors: <span set:html={e.supervisors} />
              </div>
            )}
            {e.grade && <div class="detail muted">Grade: {e.grade}</div>}
            {e.activities && <div class="detail muted">{e.activities}</div>}
            {e.thesis && (
              <div class="detail muted">
                Thesis: <span class="thesis" set:html={e.thesis} />
              </div>
            )}
          </span>
        </li>
      ))
    }
  </ul>

  <h2>Experience</h2>
  <ul class="timeline">
    {
      experience.map((e) => (
        <li>
          <span class="when">{e.when}</span>
          <span class="what">
            <strong>{e.what}</strong>
            <br />
            <span class="muted">{e.where}</span>
          </span>
        </li>
      ))
    }
  </ul>

  <h2>Skills &amp; languages</h2>
  <ul class="pill-row">
    {skills.map((s) => <li class="tag">{s}</li>)}
  </ul>
</BaseLayout>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .timeline li {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.5rem 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .when {
    color: var(--text-soft);
    font-size: 0.9rem;
  }
  .detail {
    font-size: 0.92rem;
    margin-top: 0.25rem;
  }
  .thesis {
    font-style: italic;
  }
  @media (max-width: 540px) {
    .timeline li {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
