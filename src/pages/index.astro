---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, LINKS, LAB_URL } from "../consts";
import { timeline } from "../data/timeline";

// Newest milestone first, then grouped by year for the timeline headings.
const milestones = [...timeline].sort((a, b) => b.date.localeCompare(a.date));
const years = [...new Set(milestones.map((m) => m.date.slice(0, 4)))];
const byYear = years.map((year) => ({
  year,
  items: milestones.filter((m) => m.date.startsWith(year)),
}));

// Research interests shown as pills. Edit freely.
const interests = [
  "Human-centric lighting",
  "Spatially adaptive lighting",
  "Non-visual effects of light",
  "Virtual reality & digital twins",
  "Daylight integration",
  "Lighting metrics & control",
];

// Inline SVG icons (24x24). Kept here so the page needs no external requests.
const ICONS: Record<string, string> = {
  email:
    '<path fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" d="M3 5.5h18a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-11a1 1 0 0 1 1-1z"/><path fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" d="m2.6 6.4 9.4 6.6 9.4-6.6"/>',
  kuleuven:
    '<path fill="currentColor" d="M12 3 1 9l4 2.18V17c0 .37.2.71.53.88L12 21l6.47-3.12A1 1 0 0 0 19 17v-5.82L21 10.1V16h2V9L12 3zm0 2.28L18.9 9 12 12.72 5.1 9 12 5.28zM17 12.27V16.4l-5 2.41-5-2.41v-4.13l4.53 2.47a1 1 0 0 0 .94 0L17 12.27z"/>',
  orcid:
    '<path fill="currentColor" d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378a.947.947 0 1 1 0 1.894.947.947 0 0 1 0-1.894zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/>',
  github:
    '<path fill="currentColor" d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.05-.02-2.06-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.29 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/>',
  linkedin:
    '<path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>',
};

// Icon links shown under the photo. Entries with an empty href are hidden.
const social = [
  { key: "email", label: "Email", href: LINKS.email },
  { key: "kuleuven", label: "KU Leuven", href: LINKS.kuleuven },
  { key: "orcid", label: "ORCID", href: LINKS.orcid },
  { key: "github", label: "GitHub", href: LINKS.github },
  { key: "linkedin", label: "LinkedIn", href: LINKS.linkedin },
].filter((l) => l.href);
---

<BaseLayout>
  <section class="intro">
    <div class="intro-text">
      <h1>{SITE.name}</h1>
      <p class="lead">
        {SITE.role}, {SITE.affiliation}.
      </p>
      <p>
        I'm a PhD researcher at the
        <a href={LAB_URL}>Light &amp; Lighting Laboratory</a>, KU Leuven. I work
        on lighting that can change its shape, more formally called spatially adaptive 
        lighting. Instead of a fixed radiation pattern, these
        luminaires can radiate light exactly where it's needed and keep adjusting as
        the daylight shifts through the day and people move around the room. More specifically, my goal is to 
        build a digital twin of the hardware, to then design control algorithms that 
        balance visual comfort, non-visual effects (like your body clock), and energy use.
      </p>
      <p>
        Somewhere down the line, I'd like to use VR to make things more accessible for people with impairments.
      </p>
      <p>
        If any of this sounds interesting and you would like to collab, feel free to reach out:
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>

      <ul class="pill-row">
        {interests.map((i) => <li class="tag">{i}</li>)}
      </ul>
    </div>

    <aside class="intro-photo">
      <!-- Swap the photo by replacing public/profile.jpg. -->
      <img
        class="avatar"
        src="/profile.jpg"
        alt="Portrait of Klaas Meersman"
        width="400"
        height="400"
        loading="eager"
      />
      <ul class="social-icons">
        {
          social.map((l) => (
            <li>
              <a
                href={l.href}
                aria-label={l.label}
                title={l.label}
                rel={l.href.startsWith("mailto:") ? undefined : "me noopener"}
              >
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                  <Fragment set:html={ICONS[l.key]} />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </aside>
  </section>

  <h2>Currently</h2>
  <p>
    I'm researching daylight simulations and how to make them more accessible to non-experts, 
    with the goal of facilitating the incorporation of human-centric lighting in building design. 
    A central aim of this work is to predict melanopic EDI, a metric for the non-visual effects
    of light on the human body, at any location and time, as accurately as possible.
  </p>

  <h2>Timeline</h2>
  <div class="timeline-v">
    {
      byYear.map((group) => (
        <section class="tl-group">
          <h3 class="tl-year">{group.year}</h3>
          <ol>
            {group.items.map((m) => (
              <li>
                <span class="tl-date muted">{m.display}</span>
                <div class="tl-body">
                  <strong class="tl-title">
                    {m.url ? (
                      <a href={m.url} set:html={m.title} />
                    ) : (
                      <Fragment set:html={m.title} />
                    )}
                  </strong>
                  {m.detail && <p class="muted tl-detail" set:html={m.detail} />}
                </div>
              </li>
            ))}
          </ol>
        </section>
      ))
    }
  </div>

</BaseLayout>

<style>
  .intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (min-width: 640px) {
    .intro {
      grid-template-columns: 1fr auto;
    }
  }
  .intro-photo {
    text-align: center;
    max-width: 12rem;
  }
  .avatar {
    width: 9rem;
    height: 9rem;
    border-radius: 50%;
    margin: 0 auto;
    display: block;
    /* Crop to a circle without squashing the photo. */
    object-fit: cover;
    background: var(--accent-soft);
    border: 1px solid var(--border);
  }
  /* Vertical timeline: one continuous line, a year heading per group
     (large hollow ring) and a small filled dot per milestone. */
  .timeline-v {
    margin: 0;
    padding: 0;
  }
  .tl-group ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Year heading sits on the line with a hollow ring. */
  .tl-year {
    position: relative;
    margin: 0;
    padding: 0 0 0.9rem 1.6rem;
    border-left: 2px solid var(--border);
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text);
  }
  .tl-year::before {
    content: "";
    position: absolute;
    left: -0.53rem;
    top: 0.35rem;
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
  }
  /* Breathing room between year groups. */
  .tl-group + .tl-group .tl-year {
    padding-top: 1.4rem;
  }

  .tl-group li {
    position: relative;
    padding: 0 0 1.4rem 1.6rem;
    border-left: 2px solid var(--border);
  }
  .tl-group li::before {
    content: "";
    position: absolute;
    left: -0.32rem;
    top: 0.45rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--accent);
  }
  /* End the line after the very last milestone. */
  .tl-group:last-child li:last-child {
    border-left-color: transparent;
    padding-bottom: 0;
  }

  .tl-date {
    display: block;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .tl-title {
    font-family: var(--font-serif);
    font-weight: 600;
  }
  .tl-detail {
    margin: 0.2rem 0 0;
    font-size: 0.95rem;
  }

  /* Icon links under the photo. Labels live in aria-label/title, so they stay
     accessible to screen readers and show on hover. */
  .social-icons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.85rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }
  .social-icons a {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    color: var(--text-soft);
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }
  .social-icons a:hover {
    color: var(--accent);
    background: var(--accent-soft);
    text-decoration: none;
  }
  .social-icons svg {
    display: block;
  }
</style>
