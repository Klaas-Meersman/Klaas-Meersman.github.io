---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../consts";

// Courses I'm involved in. Add new entries here as they come up.
const teaching = [
  {
    role: "Lab sessions",
    course: "Communication Networks",
    detail: "KU Leuven, Ghent Technology Campus",
    period: "2025 – present",
  },
  {
    role: "Teaching assistant",
    course: "Electromagnetic Waves and Antennas",
    detail: "KU Leuven, Ghent Technology Campus",
    period: "2025 – present",
  },
];
---

<BaseLayout
  title="Teaching"
  description="Teaching and student supervision by Klaas Meersman."
>
  <h1>Teaching</h1>
  <p class="lead">Courses I help teach at KU Leuven's Ghent Technology Campus.</p>

  <ul class="teach-list">
    {
      teaching.map((t) => (
        <li>
          <strong>{t.role}</strong> — {t.course}
          <div class="muted small">
            {t.detail} · {t.period}
          </div>
        </li>
      ))
    }
  </ul>

  <h2>Interested in a thesis topic?</h2>
  <p>
    If you're a student looking for a thesis or internship around lighting,
    daylight simulation, or VR, feel free to
    <a href={`mailto:${SITE.email}`}>get in touch</a>. I'm always happy to talk
    through ideas.
  </p>
</BaseLayout>

<style>
  .teach-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .teach-list li {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
  }
  .small {
    font-size: 0.85rem;
    margin-top: 0.2rem;
  }
</style>
