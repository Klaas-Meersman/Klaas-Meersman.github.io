---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <div class="notfound">
    <h1>404</h1>
    <p class="lead">This page could not be found.</p>
    <p><a href="/">← Back home</a></p>
  </div>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding-block: 3rem;
  }
  .notfound h1 {
    font-size: 4rem;
    margin-bottom: 0.5rem;
  }
</style>
