---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

// Generate one page per note file.
export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout title={note.data.title} description={note.data.summary}>
  <article class="note">
    <p class="muted"><a href="/notes">← All notes</a></p>
    <h1>{note.data.title}</h1>
    <p class="muted note-date">
      <time datetime={note.data.date.toISOString()}>{fmt(note.data.date)}</time>
      {
        note.data.tags.length > 0 && (
          <span class="pill-inline">
            {note.data.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </span>
        )
      }
    </p>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .note-date {
    margin-top: -0.25rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  /* `prose` gives the rendered Markdown comfortable spacing. */
  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
  }
  .prose :global(h2) {
    margin-top: 2.25rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.3rem;
  }
  .prose :global(li) {
    margin-bottom: 0.35rem;
  }
</style>
